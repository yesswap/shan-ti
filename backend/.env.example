# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/threatlens

# ─── App ──────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Option A: Gmail — enable "App Passwords" in Google account, use that as SMTP_PASS
# Option B: Resend.com — free 3000 emails/mo, SMTP on smtp.resend.com:587
# Option C: Brevo (Sendinblue) — free 300 emails/day
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@threatlens.io

# ─── Optional Intel Sources ───────────────────────────────────────────────────
# Free API key from https://otx.alienvault.com (sign up, no payment)
OTX_API_KEY=

# ─── Debug ────────────────────────────────────────────────────────────────────
SQL_ECHO=false
